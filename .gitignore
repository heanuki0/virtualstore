src/**/*.js.map
src/**/*.d.ts
!src/vite-env.d.ts
scripts/**/*.js
scripts/**/*.d.ts
vite.config.js
vite.config.d.ts
tailwind.config.js
tailwind.config.d.ts
postcss.config.d.ts
